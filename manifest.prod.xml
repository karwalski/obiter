<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<OfficeApp xmlns="http://schemas.microsoft.com/office/appforoffice/1.1" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:bt="http://schemas.microsoft.com/office/officeappbasictypes/1.0" xmlns:ov="http://schemas.microsoft.com/office/taskpaneappversionoverrides" xsi:type="TaskPaneApp">
  <Id>933c30ed-e129-4844-9880-c4009e3969a5</Id>
  <Version>1.6.0.0</Version>
  <ProviderName>Matthew Watt</ProviderName>
  <DefaultLocale>en-US</DefaultLocale>
  <DisplayName DefaultValue="Obiter — AGLC4 Citation Engine"/>
  <Description DefaultValue="Full AGLC4 citation formatting, document validation, and bibliography generation for Microsoft Word."/>
  <IconUrl DefaultValue="https://obiter.com.au/app/assets/icon-32.png?v=160"/>
  <HighResolutionIconUrl DefaultValue="https://obiter.com.au/app/assets/icon-64.png?v=160"/>
  <SupportUrl DefaultValue="https://obiter.com.au"/>
  <AppDomains>
    <AppDomain>https://obiter.com.au</AppDomain>
  </AppDomains>
  <Hosts>
    <Host Name="Document"/>
  </Hosts>
  <Requirements>
    <Sets>
      <Set Name="WordApi" MinVersion="1.5"/>
    </Sets>
  </Requirements>
  <DefaultSettings>
    <SourceLocation DefaultValue="https://obiter.com.au/app/taskpane.html"/>
  </DefaultSettings>
  <Permissions>ReadWriteDocument</Permissions>
  <VersionOverrides xmlns="http://schemas.microsoft.com/office/taskpaneappversionoverrides" xsi:type="VersionOverridesV1_0">
    <Hosts>
      <Host xsi:type="Document">
        <DesktopFormFactor>
          <GetStarted>
            <Title resid="GetStarted.Title"/>
            <Description resid="GetStarted.Description"/>
            <LearnMoreUrl resid="GetStarted.LearnMoreUrl"/>
          </GetStarted>
          <FunctionFile resid="Commands.Url"/>
          <ExtensionPoint xsi:type="PrimaryCommandSurface">
            <CustomTab id="ObiterTab">

              <!-- ── Citation Group ── -->
              <Group id="CitationGroup">
                <Label resid="CitationGroup.Label"/>
                <Icon>
                  <bt:Image size="16" resid="Icon.16x16"/>
                  <bt:Image size="32" resid="Icon.32x32"/>
                  <bt:Image size="80" resid="Icon.80x80"/>
                </Icon>

                <!-- Show Obiter Pane (opens task pane to default view) -->
                <Control xsi:type="Button" id="ShowPaneBtn">
                  <Label resid="ShowPane.Label"/>
                  <Supertip>
                    <Title resid="ShowPane.Label"/>
                    <Description resid="ShowPane.Tooltip"/>
                  </Supertip>
                  <Icon>
                    <bt:Image size="16" resid="Icon.16x16"/>
                    <bt:Image size="32" resid="Icon.32x32"/>
                    <bt:Image size="80" resid="Icon.80x80"/>
                  </Icon>
                  <Action xsi:type="ShowTaskpane">
                    <TaskpaneId>ButtonId1</TaskpaneId>
                    <SourceLocation resid="Taskpane.Url"/>
                  </Action>
                </Control>

                <!-- Insert Citation (opens task pane to Insert view) -->
                <Control xsi:type="Button" id="InsertCitationBtn">
                  <Label resid="InsertCitation.Label"/>
                  <Supertip>
                    <Title resid="InsertCitation.Label"/>
                    <Description resid="InsertCitation.Tooltip"/>
                  </Supertip>
                  <Icon>
                    <bt:Image size="16" resid="Icon.Insert.16x16"/>
                    <bt:Image size="32" resid="Icon.Insert.32x32"/>
                    <bt:Image size="80" resid="Icon.Insert.80x80"/>
                  </Icon>
                  <Action xsi:type="ShowTaskpane">
                    <TaskpaneId>ButtonId1</TaskpaneId>
                    <SourceLocation resid="Taskpane.Url"/>
                  </Action>
                </Control>

                <!-- Citation Library -->
                <Control xsi:type="Button" id="LibraryBtn">
                  <Label resid="Library.Label"/>
                  <Supertip>
                    <Title resid="Library.Label"/>
                    <Description resid="Library.Tooltip"/>
                  </Supertip>
                  <Icon>
                    <bt:Image size="16" resid="Icon.Library.16x16"/>
                    <bt:Image size="32" resid="Icon.Library.32x32"/>
                    <bt:Image size="80" resid="Icon.Library.80x80"/>
                  </Icon>
                  <Action xsi:type="ShowTaskpane">
                    <TaskpaneId>ButtonId1</TaskpaneId>
                    <SourceLocation resid="Taskpane.Library.Url"/>
                  </Action>
                </Control>
              </Group>

              <!-- ── Document Group ── -->
              <Group id="DocumentGroup">
                <Label resid="DocumentGroup.Label"/>
                <Icon>
                  <bt:Image size="16" resid="Icon.16x16"/>
                  <bt:Image size="32" resid="Icon.32x32"/>
                  <bt:Image size="80" resid="Icon.80x80"/>
                </Icon>

                <!-- Validate Document -->
                <Control xsi:type="Button" id="ValidateBtn">
                  <Label resid="Validate.Label"/>
                  <Supertip>
                    <Title resid="Validate.Label"/>
                    <Description resid="Validate.Tooltip"/>
                  </Supertip>
                  <Icon>
                    <bt:Image size="16" resid="Icon.Validate.16x16"/>
                    <bt:Image size="32" resid="Icon.Validate.32x32"/>
                    <bt:Image size="80" resid="Icon.Validate.80x80"/>
                  </Icon>
                  <Action xsi:type="ShowTaskpane">
                    <TaskpaneId>ButtonId1</TaskpaneId>
                    <SourceLocation resid="Taskpane.Validate.Url"/>
                  </Action>
                </Control>

                <!-- Bibliography -->
                <Control xsi:type="Button" id="BibliographyBtn">
                  <Label resid="Bibliography.Label"/>
                  <Supertip>
                    <Title resid="Bibliography.Label"/>
                    <Description resid="Bibliography.Tooltip"/>
                  </Supertip>
                  <Icon>
                    <bt:Image size="16" resid="Icon.Bibliography.16x16"/>
                    <bt:Image size="32" resid="Icon.Bibliography.32x32"/>
                    <bt:Image size="80" resid="Icon.Bibliography.80x80"/>
                  </Icon>
                  <Action xsi:type="ShowTaskpane">
                    <TaskpaneId>ButtonId1</TaskpaneId>
                    <SourceLocation resid="Taskpane.Bibliography.Url"/>
                  </Action>
                </Control>

                <!-- Reference Guide -->
                <Control xsi:type="Button" id="GuideBtn">
                  <Label resid="Guide.Label"/>
                  <Supertip>
                    <Title resid="Guide.Label"/>
                    <Description resid="Guide.Tooltip"/>
                  </Supertip>
                  <Icon>
                    <bt:Image size="16" resid="Icon.Guide.16x16"/>
                    <bt:Image size="32" resid="Icon.Guide.32x32"/>
                    <bt:Image size="80" resid="Icon.Guide.80x80"/>
                  </Icon>
                  <Action xsi:type="ShowTaskpane">
                    <TaskpaneId>ButtonId1</TaskpaneId>
                    <SourceLocation resid="Taskpane.Guide.Url"/>
                  </Action>
                </Control>

                <!-- Refresh All -->
                <Control xsi:type="Button" id="RefreshAllBtn">
                  <Label resid="RefreshAll.Label"/>
                  <Supertip>
                    <Title resid="RefreshAll.Label"/>
                    <Description resid="RefreshAll.Tooltip"/>
                  </Supertip>
                  <Icon>
                    <bt:Image size="16" resid="Icon.Refresh.16x16"/>
                    <bt:Image size="32" resid="Icon.Refresh.32x32"/>
                    <bt:Image size="80" resid="Icon.Refresh.80x80"/>
                  </Icon>
                  <Action xsi:type="ExecuteFunction">
                    <FunctionName>refreshAll</FunctionName>
                  </Action>
                </Control>

                <!-- Apply Template -->
                <Control xsi:type="Button" id="ApplyTemplateBtn">
                  <Label resid="ApplyTemplate.Label"/>
                  <Supertip>
                    <Title resid="ApplyTemplate.Label"/>
                    <Description resid="ApplyTemplate.Tooltip"/>
                  </Supertip>
                  <Icon>
                    <bt:Image size="16" resid="Icon.Template.16x16"/>
                    <bt:Image size="32" resid="Icon.Template.32x32"/>
                    <bt:Image size="80" resid="Icon.Template.80x80"/>
                  </Icon>
                  <Action xsi:type="ExecuteFunction">
                    <FunctionName>applyTemplate</FunctionName>
                  </Action>
                </Control>

                <!-- Block Quote -->
                <Control xsi:type="Button" id="BlockQuoteBtn">
                  <Label resid="BlockQuote.Label"/>
                  <Supertip>
                    <Title resid="BlockQuote.Label"/>
                    <Description resid="BlockQuote.Tooltip"/>
                  </Supertip>
                  <Icon>
                    <bt:Image size="16" resid="Icon.BlockQuote.16x16"/>
                    <bt:Image size="32" resid="Icon.BlockQuote.32x32"/>
                    <bt:Image size="80" resid="Icon.BlockQuote.80x80"/>
                  </Icon>
                  <Action xsi:type="ExecuteFunction">
                    <FunctionName>applyBlockQuote</FunctionName>
                  </Action>
                </Control>
              </Group>

              <!-- Heading levels available via task pane toolbar (I-V pills) -->

              <!-- ── Tools Group ── -->
              <Group id="ToolsGroup">
                <Label resid="ToolsGroup.Label"/>
                <Icon>
                  <bt:Image size="16" resid="Icon.16x16"/>
                  <bt:Image size="32" resid="Icon.32x32"/>
                  <bt:Image size="80" resid="Icon.80x80"/>
                </Icon>

                <!-- Styling -->
                <Control xsi:type="Button" id="StylingBtn">
                  <Label resid="Styling.Label"/>
                  <Supertip>
                    <Title resid="Styling.Label"/>
                    <Description resid="Styling.Tooltip"/>
                  </Supertip>
                  <Icon>
                    <bt:Image size="16" resid="Icon.Template.16x16"/>
                    <bt:Image size="32" resid="Icon.Template.32x32"/>
                    <bt:Image size="80" resid="Icon.Template.80x80"/>
                  </Icon>
                  <Action xsi:type="ShowTaskpane">
                    <TaskpaneId>ButtonId1</TaskpaneId>
                    <SourceLocation resid="Taskpane.Styling.Url"/>
                  </Action>
                </Control>

                <!-- Settings -->
                <Control xsi:type="Button" id="SettingsBtn">
                  <Label resid="Settings.Label"/>
                  <Supertip>
                    <Title resid="Settings.Label"/>
                    <Description resid="Settings.Tooltip"/>
                  </Supertip>
                  <Icon>
                    <bt:Image size="16" resid="Icon.Settings.16x16"/>
                    <bt:Image size="32" resid="Icon.Settings.32x32"/>
                    <bt:Image size="80" resid="Icon.Settings.80x80"/>
                  </Icon>
                  <Action xsi:type="ShowTaskpane">
                    <TaskpaneId>ButtonId1</TaskpaneId>
                    <SourceLocation resid="Taskpane.Settings.Url"/>
                  </Action>
                </Control>
              </Group>

              <Label resid="ObiterTab.Label"/>
            </CustomTab>
          </ExtensionPoint>
        </DesktopFormFactor>
      </Host>
    </Hosts>
