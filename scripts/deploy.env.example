# Obiter deployment configuration — TEMPLATE.
#
# Copy this file to scripts/deploy.env and fill in your real values.
# scripts/deploy.env is gitignored and must NEVER be committed.

# Server IP address or hostname (e.g. an Amazon Lightsail static IP).
OBITER_SSH_HOST=your.server.ip.or.host

# Path to the SSH private key used for deployment.
OBITER_SSH_KEY=$HOME/.ssh/your-deploy-key.pem

# SSH user (optional; defaults to "bitnami" for a standard Lightsail instance).
OBITER_SSH_USER=bitnami
